# ================================================================
# Trade Replay — Environment Variables Template
# Copy to .env and fill in real values
# ================================================================

APP_ENV=development

PORT=4000
FRONTEND_PORT=8080
CLIENT_URL=http://localhost:8080
BACKEND_URL=http://localhost:4000
API_RATE_LIMIT_MAX=2000
CHART_SERVICE_ENABLED=true
CHART_SERVICE_PORT=3009
CHART_SERVICE_URL=http://127.0.0.1:3009
CHART_SERVICE_AUTH_ENABLED=false
CHART_SERVICE_AUTH_TOKEN=
CHART_SERVICE_TIMEOUT_MS=1500
CHART_SERVICE_RETRY_COUNT=1
CHART_SERVICE_RETRY_BASE_MS=150
CHART_SERVICE_BREAKER_FAILURE_THRESHOLD=5
CHART_SERVICE_BREAKER_FAILURE_WINDOW_MS=30000
CHART_SERVICE_BREAKER_COOLDOWN_MS=30000

# --- MongoDB ---
MONGO_URI=mongodb://127.0.0.1:27017/tradereplay

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- Kafka ---
KAFKA_ENABLED=true
KAFKA_BROKER=localhost:19092
KAFKA_DEFAULT_PARTITIONS=3
KAFKA_SYMBOL_EVENT_PARTITIONS=6
KAFKA_PORTFOLIO_EVENT_PARTITIONS=6
ANALYTICS_CONSUMER_GROUP=tradereplay-analytics-processor
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# --- Auth / Security ---
JWT_SECRET=                          # Generate: openssl rand -hex 32
CURSOR_SIGNING_SECRET=               # Generate: openssl rand -hex 32
GOOGLE_CLIENT_ID=                    # From Google Cloud Console

# --- AWS / S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
AWS_CDN_BASE_URL=
AWS_IAM_USER_NAME=
AWS_IAM_USER_ARN=
AWS_CLOUDFRONT_DISTRIBUTION_DOMAIN=
AWS_CLOUDFRONT_DISTRIBUTION_ARN=
AWS_S3_PUBLIC_URL=

# --- Logo Enrichment ---
LOGO_ENRICHMENT_ENABLED=true
LOGO_ENRICHMENT_INTERVAL_MS=21600000
LOGO_FALLBACK_TARGET_RATIO=0.05
LOGO_WORKER_CONCURRENCY=10

# --- API Keys (external data providers) ---
FMP_API_KEY=                         # financialmodelingprep.com
ALPHA_VANTAGE_KEY=                   # alphavantage.co
COINGECKO_API_KEY=                   # Optional — free tier works without key
OPENFIGI_API_KEY=                    # Optional — openfigi.com

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:4000/api
VITE_GOOGLE_CLIENT_ID=               # Same as GOOGLE_CLIENT_ID

# --- Misc ---
USD_TO_INR=83.5
LOG_REQUEST_SAMPLE_RATE=0.1
